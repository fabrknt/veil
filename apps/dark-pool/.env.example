# Veil Dark Pool — Solver Configuration
#
# RPC Provider (pick one)
# QuickNode is recommended for production — supports Streams for real-time commitment detection
# QUICKNODE_ENDPOINT=https://your-endpoint.quiknode.pro/your-api-key/
# HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=your-key
# RPC_URL=http://localhost:8899

# Solver wallet
SOLVER_KEYPAIR_PATH=~/.config/solana/id.json

# Encryption (32-byte hex seed for deterministic keypair, or omit for ephemeral)
# ENCRYPTION_SEED=your-64-char-hex-string

# Program
PROGRAM_ID=FPAF4iwMtb2CWDcqpWf6NJzJCYrBhQNH8PkWY8ZCGMUA

# Solver settings
POLL_INTERVAL_MS=2000
API_PORT=3040
DEFAULT_VENUE=drift
